# Expo / Metro — Convex React Native Quickstart endpoint (your deployment dashboard).
EXPO_PUBLIC_CONVEX_URL=https://YOUR-DEPLOYMENT.convex.cloud

# Convex CLI (dashboard → Project settings → Development deployment).
# Paste into `.env.local` — do NOT commit `.env.local` if it holds secrets (JWT keys belong in Convex dashboard).
# CONVEX_DEPLOYMENT=dev:your-deployment
#
# Dev deployment only (Profile → Delete account): npx convex env set DEBTLY_ALLOW_ACCOUNT_DELETE true
